# ── General ──
aws_region   = "eu-north-1"
environment  = "dev"
project_name = "data-archival"

# ── S3 Lifecycle Thresholds ──
intelligent_tiering_days  = 30
glacier_days              = 90
glacier_deep_archive_days = 365

# ── RDS ──
db_name           = "archival_db"
db_username       = "archival_admin"
db_password       = "ArchivalSecure2025!"
db_instance_class = "db.t3.micro"

# ── Lambda ──
lambda_timeout           = 300
lambda_memory            = 256
cold_data_threshold_days = 90

# ── Networking ──
vpc_cidr = "10.0.0.0/16"
my_ip    = "0.0.0.0/0"  # Replace with your IP: curl ifconfig.me
